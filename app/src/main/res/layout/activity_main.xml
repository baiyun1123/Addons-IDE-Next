<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_root_gradient">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|end"
        android:alpha="0.95"
        android:background="@drawable/bg_hero_orb" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_20">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/topbarOverline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/topbar_overline"
                    android:textAllCaps="true"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/topbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/home_page_title"
                    android:textColor="@color/md_theme_onBackground"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/topbarSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/home_page_subtitle"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/md_theme_surfaceContainer"
                app:cardCornerRadius="@dimen/radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/topbarBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/space_16"
                    android:paddingVertical="@dimen/space_12"
                    android:text="@string/topbar_badge"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/pageContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/homePage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingStart="@dimen/screen_padding"
                android:paddingEnd="@dimen/screen_padding"
                android:paddingBottom="@dimen/space_16"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/homeSummaryCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_16"
                        app:cardBackgroundColor="@color/md_theme_primaryContainer"
                        app:cardCornerRadius="@dimen/radius_xlarge"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_20">

                            <com.google.android.material.chip.Chip
                                style="@style/Widget.Material3.Chip.Assist"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_summary_chip"
                                app:chipBackgroundColor="@color/hero_chip_background"
                                app:chipStrokeWidth="0dp"
                                app:ensureMinTouchTargetSize="false" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_16"
                                android:text="@string/home_summary_title"
                                android:textColor="@color/md_theme_onPrimaryContainer"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_12"
                                android:lineSpacingExtra="4dp"
                                android:text="@string/home_summary_description"
                                android:textColor="@color/hero_support_text"
                                android:textSize="14sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_20"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="@dimen/space_8"
                                    app:cardBackgroundColor="@color/md_theme_secondaryContainer"
                                    app:cardCornerRadius="@dimen/radius_large"
                                    app:cardElevation="0dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:padding="@dimen/space_16">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/home_stat_projects"
                                            android:textColor="@color/md_theme_onSecondaryContainer"
                                            android:textSize="12sp" />

                                        <TextView
                                            android:id="@+id/projectCountValue"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:text="0"
                                            android:textColor="@color/md_theme_onSecondaryContainer"
                                            android:textSize="22sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="@dimen/space_8"
                                    app:cardBackgroundColor="@color/md_theme_surface"
                                    app:cardCornerRadius="@dimen/radius_large"
                                    app:cardElevation="0dp"
                                    app:strokeColor="@color/md_theme_outlineVariant"
                                    app:strokeWidth="1dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:padding="@dimen/space_16">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/home_stat_latest"
                                            android:textColor="@color/md_theme_onSurfaceVariant"
                                            android:textSize="12sp" />

                                        <TextView
                                            android:id="@+id/latestProjectValue"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:ellipsize="end"
                                            android:maxLines="1"
                                            android:text="@string/home_stat_latest_empty"
                                            android:textColor="@color/md_theme_onSurface"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/projectListSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="@dimen/space_24">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/project_list_title"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:layout_marginBottom="@dimen/space_12"
                            android:text="@string/project_list_description"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="14sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/projectRecycler"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clipToPadding="false"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never"
                                android:paddingBottom="@dimen/space_24"
                                android:scrollbars="none" />

                            <LinearLayout
                                android:id="@+id/emptyStateGroup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/space_24"
                                android:visibility="gone">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:cardBackgroundColor="@color/md_theme_surface"
                                    app:cardCornerRadius="@dimen/radius_xlarge"
                                    app:cardElevation="0dp"
                                    app:strokeColor="@color/md_theme_outlineVariant"
                                    app:strokeWidth="1dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_horizontal"
                                        android:orientation="vertical"
                                        android:padding="@dimen/space_24">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/empty_title"
                                            android:textColor="@color/md_theme_onSurface"
                                            android:textSize="18sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/space_12"
                                            android:gravity="center"
                                            android:text="@string/empty_description"
                                            android:textColor="@color/md_theme_onSurfaceVariant"
                                            android:textSize="14sp" />

                                        <com.google.android.material.button.MaterialButton
                                            android:id="@+id/emptyCreateButton"
                                            style="@style/Widget.Material3.Button"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/space_20"
                                            android:text="@string/empty_action"
                                            app:cornerRadius="@dimen/radius_large" />
                                    </LinearLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/profilePage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingStart="@dimen/screen_padding"
                android:paddingEnd="@dimen/screen_padding"
                android:paddingBottom="@dimen/space_24"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/profileHeroCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_16"
                        app:cardBackgroundColor="@color/md_theme_tertiaryContainer"
                        app:cardCornerRadius="@dimen/radius_xlarge"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_20">

                            <com.google.android.material.chip.Chip
                                style="@style/Widget.Material3.Chip.Assist"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_chip"
                                app:chipStrokeWidth="0dp"
                                app:ensureMinTouchTargetSize="false" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_16"
                                android:text="@string/profile_title"
                                android:textColor="@color/md_theme_onTertiaryContainer"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/workspacePathText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_12"
                                android:textColor="@color/md_theme_onTertiaryContainer"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_16"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="@dimen/radius_xlarge"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/md_theme_outlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_20">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_defaults_title"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:text="@string/profile_defaults_description"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="14sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_20"
                                android:hint="@string/profile_author_hint"
                                app:boxCornerRadiusBottomEnd="@dimen/radius_large"
                                app:boxCornerRadiusBottomStart="@dimen/radius_large"
                                app:boxCornerRadiusTopEnd="@dimen/radius_large"
                                app:boxCornerRadiusTopStart="@dimen/radius_large">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/profileAuthorInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_12"
                                android:hint="@string/profile_version_hint"
                                app:boxCornerRadiusBottomEnd="@dimen/radius_large"
                                app:boxCornerRadiusBottomStart="@dimen/radius_large"
                                app:boxCornerRadiusTopEnd="@dimen/radius_large"
                                app:boxCornerRadiusTopStart="@dimen/radius_large">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/profileVersionInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_12"
                                android:hint="@string/profile_description_hint"
                                app:boxCornerRadiusBottomEnd="@dimen/radius_large"
                                app:boxCornerRadiusBottomStart="@dimen/radius_large"
                                app:boxCornerRadiusTopEnd="@dimen/radius_large"
                                app:boxCornerRadiusTopStart="@dimen/radius_large">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/profileDescriptionInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top|start"
                                    android:inputType="textMultiLine"
                                    android:lines="3" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/profileResourceSwitch"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_16"
                                android:text="@string/profile_resource_switch" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/saveSettingsButton"
                                style="@style/Widget.Material3.Button"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_20"
                                android:text="@string/profile_save_button"
                                app:cornerRadius="@dimen/radius_large" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="@dimen/radius_xlarge"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/md_theme_outlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_20">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_policy_title"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:text="@string/profile_policy_description"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/profileDocLinksText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_16"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addProjectFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/fab_bottom_margin"
        android:contentDescription="@string/create_project_action"
        android:src="@drawable/ic_add_24"
        app:backgroundTint="@color/md_theme_primary"
        app:tint="@color/md_theme_onPrimary" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/bottom_bar_background"
        android:elevation="8dp"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/space_8"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/space_8"
        app:itemIconTint="@color/navigation_item_color"
        app:itemTextColor="@color/navigation_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</FrameLayout>
